{
  "name": "three-template",
  "private": true,
  "type": "module",
  "module": "server.ts",
  "scripts": {
    "dev": "bun --hot ./server.ts",
    "start": "bun run dev",
    "fmt": "oxfmt server.ts index.html src package.json README.md tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "fmt:fix": "bun run fmt",
    "fmt:check": "oxfmt --check server.ts index.html src package.json README.md tsconfig.json .oxlintrc.json .oxfmtrc.json",
    "lint": "oxlint server.ts src",
    "lint:fix": "oxlint --fix server.ts src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "three": "0.183.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/three": "0.180.0",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
